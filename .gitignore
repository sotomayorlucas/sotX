# ---------------------------------------------------------------------------
# Build artifacts and external binaries used for ABI compatibility testing.
# These are downloaded/extracted host binaries (Alpine, Debian, glibc, musl,
# Wine, Weston, X11, LLVM, etc.) that we keep on disk to feed into the
# Linux/BSD personalities under sotOS but never want in version control.
# All patterns are anchored with a leading "/" to apply only at the repo root
# so that source files in subdirs with similar names are unaffected.
# ---------------------------------------------------------------------------

# Shared libraries dropped at the repo root by extraction scripts.
# (Tracked SOs like ld-musl-x86_64.so.1 and libncursesw.so.6 are explicitly
# un-ignored below so they survive these wildcards.)
/*.so
/*.so.[0-9]*
/*.so.[0-9]*.[0-9]*
/*.so.[0-9]*.[0-9]*.[0-9]*
!/ld-musl-x86_64.so.1
!/libncursesw.so.6

# Alpine / Debian / generic package archives at the repo root
/*.apk
/apk-tools-static-*
/apkidx_*.tar.gz
/*.deb

# Static host binaries dumped at the repo root for ABI experiments
/apk
/bash-static
/busybox
/coreutils-deb*
/grep
/grep_alpine
/grep.apk
/htop_extract/
/jq
/links
/lynx.apk
/sed.apk
/sed_alpine
/toybox
/weston
/weston-deps/
/wine64_test
/windows/

# Hello-world ABI smoke binaries
/hello
/hello_glibc
/hello_gnu
/hello-musl

# Linker / runtime artifacts at the repo root
/ld-linux-x86-64.so.2
/ld-musl-alpine.so.1
/libLLVM-19.so
/libLLVM.so.19
/libLLVM.so.19.[0-9]*

# Terminfo / xkb compiled tables dropped at the repo root
/terminfo-*
/xkb_*

# vendored upstream sources we sync but never commit
/vendor/buildrump.sh/
/vendor/freebsd-dtrace/sys/

# LKL build outputs (lkl/README.md, lkl/build-lkl.sh, lkl/lkl_defconfig stay tracked)
/lkl/linux/
/lkl/output/
/justfile.lkl

# LaTeX intermediates (the .tex and .pdf outputs are committed)
docs/*.aux
docs/*.log
docs/*.out
docs/*.toc

# Misc local doc exports never meant to be tracked
docs/sotOS_Roadmap_Ingenieria.docx
/universal_pipeline_thesis_v2.pdf

# Python bytecode caches under scripts/
scripts/__pycache__/

# Tier 5 Ed25519 keypair (deterministic dev seed -- regenerated by
# scripts/build_signify_manifest.py). The .rs side IS committed so init
# builds without first running `just sigmanifest`.
target/sigkey.bin
target/sigmanifest

# Editor / OS noise
.DS_Store

# TLC model-checker artifacts
formal/*_TTrace_*.tla
formal/*_TTrace_*.bin
formal/states/
tools/tlc.jar
